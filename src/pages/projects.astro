---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCardPublication from "../components/HorizontalCardPublication.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { publicationEntries } from "../data/publications";

const baseUrl = import.meta.env.BASE_URL;
const publications = publicationEntries.map((paper) => ({
  ...paper,
  img: paper.img ? `${baseUrl}${paper.img}` : "",
}));
---

<BaseLayout title = "Research & Projects" sideBarActiveItemID="projects">
  <div>
    <div class="text-3xl w-full font-bold mb-5">Research</div>
  </div>

  <!-- Publications -->
  {publications.map((paper) => <HorizontalCardPublication {...paper} />)}

  <div class="mt-10">
    <div class="text-3xl w-full font-bold mb-5">Projects</div>
  </div>
  
  <div class="flex items-center justify-between">
    <div class="flex-1">
      <HorizontalCard
        title="Web UI Bug Detector Tool"
        img=""
        desc="Developed an automated web UI bug detection tool that identifies subtle non-crash defects, such as sorting inconsistencies and element occlusions, by integrating visual language models with hypothesis-driven visual cueing. The system leverages attention heatmaps and bounding boxes to focus model reasoning, significantly improving detection accuracy and generating structured, actionable bug reports."
        url="#"
        badge="AI Engineer/Front-end Developer/Back-end Developer"
        target="_self"
      />
      <div class="text-sm text-gray-500 mt-2">Date: Sep 2025</div>
    </div>
    <a href="https://github.com/lechicuong2k3/VizLint" target="_blank" class="ml-4">
      <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v 3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
    </a>
  </div>

  <div class="divider my-0"></div>

  <div class="flex items-center justify-between">
    <div class="flex-1">
      <HorizontalCard
        title="Clinical Rotation website"
        img=""
        desc="Developed a website that can effectively produce the most appropriate clinical rotation including schedules for medical students, nursing students, and residents, by using data from the academic training programs from CHS (College of Health Sciences) at Vin University"
        url="#"
        badge="Front-end Developer/Back-end Developer"
        target="_self"
      />
      <div class="text-sm text-gray-500 mt-2">Date: Jan 2023</div>
    </div>
    <a href="https://github.com/VinCPR" target="_blank" class="ml-4">
      <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v 3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
    </a>
  </div>

  <div class="divider my-0"></div>

  <div class="flex items-center justify-between">
    <div class="flex-1">
      <HorizontalCard
        title="UNIFIX start-up"
        img=""
        desc="Took on the position of CTO for an edu-tech startup called UNIFIX, which has successfully raised $2000 in funding. Co-ordinated development decisions with clients and managed team with Agile methodology."
        url="#"
        badge="Front-end Developer/Scrum Master/Product Manager"
        target="_self"
      />
      <div class="text-sm text-gray-500 mt-2">Date: Dec 2022</div>
    </div>
    <a href="https://github.com/lavacakechef/Unifix-dev" target="_blank" class="ml-4">
      <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v 3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
    </a>
  </div>

  <div class="divider my-0"></div>

  <div class="flex items-center justify-between">
    <div class="flex-1">
      <HorizontalCard
        title="Food Menu Translator AI-integrated website"
        img=""
        desc="Used React.js to develop front-end interface for a web app that help enhancing tourists' food experience. Main functions: Explore nearby restaurants' location, menu, and reputation; Save favorite restaurants for future use; Find restaurants based on food name, Extract food list from menu image"
        url="#"
        badge="Front-end Developer"
        target="_self"
      />
      <div class="text-sm text-gray-500 mt-2">Date: Aug 2022</div>
    </div>
    <a href="https://github.com/oadtq/food-menu-translator" target="_blank" class="ml-4">
      <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v 3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
    </a>
  </div>

  <div class="divider my-0"></div>

  <div class="flex items-center justify-between">
    <div class="flex-1">
      <HorizontalCard
        title="Brick Breaker Java App"
        img=""
        desc="Built a desktop app in Java in which the player must smash a wall of bricks by deflecting a bouncing ball with a paddle, whenever the ball touches a brick, it will disappear, and the player wins when breaking all the bricks or loses when failing to catch the ball with the paddle. Created and used many types of Data Structure and classes that are organized by Object Oriented Programming style."
        url="#"
        badge="Java Developer"
        target="_self"
      />
      <div class="text-sm text-gray-500 mt-2">Date: Mar 2022</div>
    </div>
    <a href="https://github.com/linhledieu/NewBrickBreaker" target="_blank" class="ml-4">
      <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v 3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
    </a>
  </div>
</BaseLayout>

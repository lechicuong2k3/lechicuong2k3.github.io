---
const { title, img, authors, author_index, author_note, abstract, url, badge, award_badge, tags, target = "_blank" } = Astro.props;
const tag_url = url && url !== "#" ? url.split("/").slice(0, -1).join("/") + "/tag" : "";
const hasImage = Boolean(img);
const highlightedAuthorIndices = Array.isArray(author_index) ? author_index : [author_index];
const placeholderLabel =
  badge && (badge.includes("Preprint") || badge.includes("preprint"))
    ? "Research Preprint"
    : "Research Publication";
// let showFullDesc = false;
// function toggleDescription() {
//   showFullAbstract = !showFullAbstract;
// }
---

<div
  class="rounded-lg bg-base-100 hover:shadow-xl transition ease-in-out hover:scale-[102%]"
>
  <a href={url} target={target}>
    <div class="hero-content flex-col md:flex-row">
      <div class="w-full md:w-[16rem] h-44 shrink-0 rounded-lg bg-white border border-base-300 overflow-hidden flex items-center justify-center">
        {
          hasImage ? (
            <img
              src={img}
              alt={title}
              class="block w-full h-auto"
              loading="lazy"
            />
          ) : (
            <div class="w-full h-full rounded-md bg-white flex flex-col justify-between p-4 text-left">
              <div class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">
                {placeholderLabel}
              </div>
              <div class="text-lg font-bold leading-snug text-slate-700 line-clamp-4">
                {title}
              </div>
            </div>
          )
        }
      </div>
      <div class="grow w-full">
        <div class="flex flex-wrap items-center gap-2">
          {badge && (
            <div class={`badge ${badge.includes("Preprint") || badge.includes("preprint") ? "badge-error" : "badge-primary"}`}>
              {badge}
            </div>
          )}
          {award_badge && (
            <div class="badge badge-warning">
              {award_badge}
            </div>
          )}
        </div>
        <h1 class="text-lg md:text-xl font-bold">
          {title}
        </h1>
        <p class="py-2 text-base md:text-lg font-regular">
          {authors.map((author, index) => (
            <span class={highlightedAuthorIndices.includes(index) ? "font-bold" : ""}>
              {author}{index < authors.length - 1 ? ', ' : ''}
            </span>
          ))}
        </p>
        {author_note && (
          <p class="pb-2 text-sm italic opacity-80">{author_note}</p>
        )}
        <div class="relative">
          {abstract && (
            <p class="text-sm md:text-base leading-relaxed line-clamp-3">
              {abstract}
            </p>
          )}
          <!-- <button class="text-primary underline" on:click={toggleDescription}>
            {showFullDesc ? "Read less" : "Read more"}
          </button> -->
        </div>
        <div class="card-actions justify-end">
          {
            tags &&
              tags.map((tag) => (
                <a href={`${tag_url}/${tag}`} class="badge badge-outline">
                  {tag}
                </a>
              ))
          }
        </div>
      </div>
    </div>
  </a>
</div>
